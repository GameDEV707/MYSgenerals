{
  "appId": "com.mys.generals",
  "productName": "MYS Generals",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**/*",
    "index.html",
    "styles.css"
  ],
  "extraMetadata": {
    "main": "dist/desktop/electron-main.js"
  },
  "win": {
    "target": ["nsis"],
    "icon": null
  },
  "mac": {
    "target": ["dmg"],
    "category": "public.app-category.games"
  },
  "linux": {
    "target": ["AppImage"]
  },
  "nsis": {
    "oneClick": true,
    "perMachine": false,
    "allowToChangeInstallationDirectory": false
  }
}
