{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2020"],
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": false,
    "declaration": false
  },
  "include": [
    "src/server/**/*.ts",
    "src/sim/**/*.ts",
    "src/host/**/*.ts",
    "src/net/protocol.ts",
    "src/net/transport.ts",
    "src/net/qr.ts",
    "src/types.ts",
    "src/constants.ts",
    "src/data.ts",
    "src/i18n.ts"
  ]
}
